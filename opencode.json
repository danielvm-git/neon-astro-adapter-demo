{
  "$schema": "https://opencode.ai/config.json",
  "instructions": ["AGENTS.md"],
  "mcp": {
    "Astro docs": {
      "type": "remote",
      "url": "https://mcp.docs.astro.build/mcp",
      "enabled": true
    },
    "Netlify": {
      "type": "local",
      "command": ["npx", "-y", "@netlify/mcp"],
      "enabled": true
    },
    "Neon": {
      "type": "remote",
      "url": "https://mcp.neon.tech/mcp",
      "enabled": true
    }
  },
  "lsp": {
    "astro": {
      "command": ["astro-ls"],
      "extensions": [".astro"]
    },
    "bash": {
      "command": ["bash-language-server", "start"],
      "extensions": [".sh"]
    }
  }
}
