---
import NavClient from "../components/NavClient.astro";

export interface Props {
  title: string;
}

const { title } = Astro.props;

const authUrl = import.meta.env.NEON_AUTH_BASE_URL;
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <style>
      :root {
        --bg: #fafafa;
        --text: #1a1a1a;
        --link: #0066cc;
        --border: #e0e0e0;
        --accent: #00e699;
      }
      html { font-family: system-ui, sans-serif; background: var(--bg); color: var(--text); }
      body { max-width: 720px; margin: 0 auto; padding: 2rem 1rem; }
      a { color: var(--link); text-decoration: none; }
      a:hover { text-decoration: underline; }
      nav { display: flex; gap: 1rem; padding-bottom: 1rem; border-bottom: 1px solid var(--border); margin-bottom: 2rem; }
      nav a { font-weight: 500; }
      button#nav-sign-out { font-weight: 500; }
    </style>
  </head>
  <body>
    <nav>
      <a href="/">Home</a>
      {authUrl ? (
        <NavClient authUrl={authUrl} />
      ) : (
        <>
          <a href="/login">Log in</a>
          <a href="/signup">Sign up</a>
        </>
      )}
    </nav>
    <main>
      <slot />
    </main>
  </body>
</html>
