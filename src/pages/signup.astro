---
import Layout from "../layouts/Layout.astro";

const NEON_AUTH_BASE_URL = import.meta.env.NEON_AUTH_BASE_URL || "";
---

<Layout title="Sign up — Neon Auth + Astro Demo">
  <h1>Sign up</h1>
  <form id="signup-form">
    <label>
      Name
      <input type="text" name="name" required autocomplete="name" />
    </label>
    <label>
      Email
      <input type="email" name="email" required autocomplete="email" />
    </label>
    <label>
      Password
      <input type="password" name="password" required autocomplete="new-password" />
    </label>
    <button type="submit">Sign up</button>
    <p id="error" role="alert" aria-live="assertive"></p>
  </form>
  <p>Already have an account? <a href="/login">Log in</a>.</p>
</Layout>

<script define:vars={{ NEON_AUTH_BASE_URL }} is:inline>
window.__NEON_AUTH_URL__ = NEON_AUTH_BASE_URL;
</script>

<script>
import { getAuthClient } from "../auth-client";

const form = document.getElementById("signup-form") as HTMLFormElement | null;
const authUrl = (window as any).__NEON_AUTH_URL__ as string | undefined;
if (form) {
  form.addEventListener("submit", async (e: Event) => {
    e.preventDefault();
    const nameInput = form.querySelector<HTMLInputElement>('input[name="name"]');
    const emailInput = form.querySelector<HTMLInputElement>('input[name="email"]');
    const passwordInput = form.querySelector<HTMLInputElement>('input[name="password"]');
    const errorEl = document.getElementById("error");
    const submitBtn = form.querySelector<HTMLButtonElement>("button");

    if (!nameInput || !emailInput || !passwordInput || !errorEl || !submitBtn) return;

    const name = nameInput.value;
    const email = emailInput.value;
    const password = passwordInput.value;

    errorEl.textContent = "";
    submitBtn.disabled = true;

    try {
      const client = getAuthClient(authUrl) as any;
      const result = await client.signUp.email({ name, email, password });
      if (result.error) {
        errorEl.textContent = "Could not create account. The email may already be in use.";
        submitBtn.disabled = false;
      } else {
        window.location.href = "/login";
      }
    } catch {
      errorEl.textContent = "Could not create account. The email may already be in use.";
      submitBtn.disabled = false;
    }
  });
}
</script>

<style>
  h1 { margin-bottom: 1.5rem; }
  form { display: flex; flex-direction: column; gap: 1rem; max-width: 360px; }
  label { display: flex; flex-direction: column; gap: 0.25rem; font-weight: 500; }
  input {
    padding: 0.5rem 0.75rem;
    border: 1px solid var(--border);
    border-radius: 4px;
    font-size: 1rem;
  }
  button {
    padding: 0.6rem 1.2rem;
    background: var(--link);
    color: #fff;
    border: none;
    border-radius: 4px;
    font-size: 1rem;
    cursor: pointer;
  }
  button:disabled { opacity: 0.6; cursor: not-allowed; }
  #error { color: #d32f2f; min-height: 1.5em; }
</style>
